# ══════════════════════════════════════════════════════════
# Mr. Chartist — Options Terminal | Environment Variables
# ══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the credentials for whichever
# broker(s) you want to use. The app works without any keys via
# TradingView + NSE — broker keys unlock real-time data.
#
# ══════════════════════════════════════════════════════════

# ── DHAN BROKER API ──
# Sign up at https://dhan.co and create a token at https://dhanhq.co/docs/v2/
# Provides: real-time option chain (with native Greeks/IV), live ticks.
#
# DHAN_CLIENT_ID=
# DHAN_ACCESS_TOKEN=

# ── ZERODHA KITE CONNECT v3 ──
# Register an app at https://developers.kite.trade/apps
# Set the app's redirect URL to:  http://localhost:4002/api/kite/callback
# Provides: option chain (composed via instruments + /quote), live ticks.
# Greeks/IV are computed locally via Black-Scholes (no native support).
#
# Note: Kite's access_token expires every day at ~06:00 IST. Use the
# "Login with Kite" button in Broker Settings each morning to refresh.
#
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_ACCESS_TOKEN=
# KITE_RISK_FREE_RATE=0.065   # used for Greeks/IV computation

# ── PROXY SERVER PORT (Optional) ──
# Default: 4002. Change only if port 4002 is already in use.
# PROXY_PORT=4002

# ── VITE PROXY URL (Optional) ──
# Default: http://localhost:4002. Change only for custom proxy setups.
# VITE_PROXY_URL=http://localhost:4002
